{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mylife",
  "version": "0.1.0",
  "identifier": "com.klsobig.mylife",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mylife",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"]
  }
}
